# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ─── Ambiente virtual ─────────────────────────────────────────
.venv/
venv/
env/
.venve1/

