.env

# ─── Dados (não versionar dados gerados) ──────────────────────
storage/bronze/*
storage/silver/*
storage/gold/*
storage/logs/*
!storage/bronze/.gitkeep
!storage/silver/.gitkeep
!storage/gold/.gitkeep
!storage/logs/.gitkeep

