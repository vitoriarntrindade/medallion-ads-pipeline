# ─── Banco de dados (PostgreSQL) ──────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ad_analytics
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=pipeline_pass

# ─── Caminhos de armazenamento ────────────────────────────────
BRONZE_PATH=storage/bronze
SILVER_PATH=storage/silver

# ─── APIs simuladas ───────────────────────────────────────────
GOOGLE_ADS_API_URL=http://localhost:8001
META_ADS_API_URL=http://localhost:8002
TIKTOK_ADS_API_URL=http://localhost:8003

# ─── Configurações gerais ─────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
